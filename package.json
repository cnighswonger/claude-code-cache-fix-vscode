{
  "name": "claude-code-cache-fix",
  "displayName": "Claude Code Cache Fix",
  "description": "Automatically loads the claude-code-cache-fix interceptor for Claude Code sessions in VS Code. Fixes prompt cache bugs that cause up to 20x cost increase.",
  "version": "0.1.0",
  "publisher": "vsitsllc",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cnighswonger/claude-code-cache-fix"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "cache",
    "prompt-caching",
    "anthropic",
    "cost-optimization"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claude-code-cache-fix.enable",
        "title": "Claude Code Cache Fix: Enable"
      },
      {
        "command": "claude-code-cache-fix.disable",
        "title": "Claude Code Cache Fix: Disable"
      },
      {
        "command": "claude-code-cache-fix.status",
        "title": "Claude Code Cache Fix: Show Status"
      }
    ]
  },
  "extensionDependencies": [],
  "funding": {
    "type": "individual",
    "url": "https://buymeacoffee.com/vsits"
  }
}
